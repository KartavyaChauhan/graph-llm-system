# Copy to .env (in this backend folder). Never commit real keys.

# --- LLM (pick one provider) ---
# gemini (default) | groq | openrouter
LLM_PROVIDER=gemini

# Google Gemini (default provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_FALLBACKS=gemini-1.5-flash,gemini-2.0-flash

# Groq — https://console.groq.com (OpenAI-compatible Chat Completions)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter — https://openrouter.ai
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=http://localhost:8000
# OPENROUTER_APP_TITLE=Graph LLM O2C

# Optional: override allowed browser origins (comma-separated). Default: Vite dev URLs only.
# CORS_ORIGINS=https://yourapp.example,http://localhost:5173
